{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "build": {
      "commands": [
        "...",
        "npx @tailwindcss/cli -i static/css/input.css -o static/css/output.css --minify"
      ]
    }
  },
  "deploy": {
    "inputs": [
      "...",
      { "step": "build", "include": ["static/"] }
    ]
  }
}
