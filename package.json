{
  "dependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  },
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i static/css/input.css -o static/css/output.css --minify",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "fix": "biome check --write ."
  }
}
